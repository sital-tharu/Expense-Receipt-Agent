# Copy to .env.local and fill in — never commit .env.local
GEMINI_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/serviceAccount.json

# Optional: anomaly detection tuning (defaults shown)
ANOMALY_MIN_AVG=200        # never flag categories averaging under this (₹/week)
ANOMALY_THRESHOLD=1.3      # flag when this week ≥ threshold × the average
ANOMALY_LOOKBACK_WEEKS=4   # weeks used to compute the average

# Exchange rates for foreign-currency receipts (INR per 1 unit).
# Any EXCHANGE_RATE_<ISO> is honored; built-in fallbacks: USD 88, EUR 95, GBP 110.
EXCHANGE_RATE_USD=96.28
# EXCHANGE_RATE_EUR=104.5

# Gmail intake (see README "Gmail intake setup")
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# GMAIL_LABEL=receipts     # Gmail label the agent reads (read-only)
# GMAIL_MAX_RESULTS=25     # max emails fetched per sync
