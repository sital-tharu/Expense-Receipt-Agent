# Copy to .env.local and fill in — never commit .env.local
GEMINI_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/serviceAccount.json

# Optional: anomaly detection tuning (defaults shown)
# ANOMALY_MIN_AVG=200        # never flag categories averaging under this (₹/week)
# ANOMALY_THRESHOLD=1.3      # flag when this week ≥ threshold × the average
# ANOMALY_LOOKBACK_WEEKS=4   # weeks used to compute the average
